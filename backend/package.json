{
  "name": "yooreed-event-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:watch": "node --import tsx/watch src/server.ts",
    "dev:tsnode": "node --loader ts-node/esm src/server.ts",
    "dev:compile": "tsc --project tsconfig.dev.json --watch",
    "dev:run": "nodemon --watch dist --exec \"node dist/server.js\"",
    "dev:alt": "concurrently \"npm run dev:compile\" \"npm run dev:run\"",
    "build": "tsc",
    "build:dev": "tsc --project tsconfig.dev.json",
    "build:bundle": "npx esbuild src/server.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/server-bundle.js --external:express --external:cors --external:helmet --external:compression --external:dotenv --external:mongoose --external:bcryptjs --external:jsonwebtoken --external:cloudinary --external:multer --external:nodemailer --external:express-rate-limit --external:express-validator",
    "start": "node dist/server.js",
    "start:bundle": "node dist/server-bundle.js",
    "start:cjs": "node server-runner.cjs",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "create-admin": "tsx src/utils/createAdmin.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^2.0.1",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@swc/core": "^1.15.7",
    "@swc/helpers": "^0.5.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^5.1.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.14",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.17.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.18.2"
  }
}
