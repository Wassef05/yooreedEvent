# ============================================
# Yooreed Events — .gitignore
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/

# Environment variables (SENSITIVE — never commit)
.env
.env.local
.env.*.local
.env.production
.env.staging

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# TypeScript cache
*.tsbuildinfo

# Vite cache
.vite/

# Coverage reports
coverage/
.nyc_output/

# Uploaded files (managed by the server, not git)
uploads/

# Misc
*.local
